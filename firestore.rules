rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /ems_csr/{document=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.email == "abdullah.baydogan@eroglums.com";
    }

    // ↓↓↓ EKLENECEK KISIM ↓↓↓
    match /ems_csr_files/{document=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.email == "abdullah.baydogan@eroglums.com";
    }

  }
}
